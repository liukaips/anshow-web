# Public DNS name and same-origin URL. Do not include a path or trailing slash.
SITE_HOST=example.com
SITE_URL=https://example.com
ACME_EMAIL=admin@example.com

# Generate two different values with: openssl rand -base64 48
# Never commit the populated .env file.
BETTER_AUTH_SECRET=
RATE_LIMIT_SECRET=

# Set MEDIA_DRIVER=cos to store public media in Tencent COS.
MEDIA_DRIVER=local
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_PUBLIC_BASE_URL=https://cdn.example.com
COS_SECRET_ID=
COS_SECRET_KEY=

# Optional SMTP worker delivery. Keep secrets server-side only.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=notifications@example.com
SALES_EMAIL=sales@example.com

# Optional OpenAI-compatible translation provider. Configure all three together.
TRANSLATION_API_URL=
TRANSLATION_API_KEY=
TRANSLATION_MODEL=

# Encrypted automatic backup worker. Generate the key with:
# openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=
BACKUP_DIR=/data/backups

# Optional local image label used by Compose.
ANSHOW_IMAGE_TAG=local
