# Public DNS name and same-origin URL. Do not include a path or trailing slash.
SITE_HOST=example.com
SITE_URL=https://example.com
ACME_EMAIL=admin@example.com

# Generate two different values with: openssl rand -base64 48
# Never commit the populated .env file.
BETTER_AUTH_SECRET=
RATE_LIMIT_SECRET=

# Optional local image label used by Compose.
ANSHOW_IMAGE_TAG=local
