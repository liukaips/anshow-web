{
  "openapi": "3.0.0",
  "info": {
    "title": "AnShow API",
    "version": "0.1.0"
  },
  "components": {
    "schemas": {
      "HealthLiveResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/HealthStatus"
          },
          "error": {
            "type": "object",
            "nullable": true,
            "enum": [
              null
            ]
          },
          "requestId": {
            "type": "string",
            "example": "71ec11f9-4be5-4305-b164-a9c30ad6207c"
          }
        },
        "required": [
          "data",
          "error",
          "requestId"
        ]
      },
      "HealthStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "ErrorEnvelope": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "nullable": true,
            "enum": [
              null
            ]
          },
          "error": {
            "$ref": "#/components/schemas/ApiError"
          },
          "requestId": {
            "type": "string",
            "example": "71ec11f9-4be5-4305-b164-a9c30ad6207c"
          }
        },
        "required": [
          "data",
          "error",
          "requestId"
        ]
      },
      "ApiError": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "AdminSessionResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/AdminSessionData"
          },
          "error": {
            "nullable": true
          },
          "requestId": {
            "type": "string"
          }
        },
        "required": [
          "data",
          "error",
          "requestId"
        ]
      },
      "AdminSessionData": {
        "type": "object",
        "properties": {
          "user": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              }
            },
            "required": [
              "id",
              "email"
            ]
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "user",
          "permissions"
        ]
      },
      "UnauthenticatedResponse": {
        "type": "object",
        "properties": {
          "data": {
            "nullable": true
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "UNAUTHENTICATED"
                ]
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ]
          },
          "requestId": {
            "type": "string"
          }
        },
        "required": [
          "data",
          "error",
          "requestId"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/health/live": {
      "get": {
        "operationId": "getHealthLive",
        "tags": [
          "Health"
        ],
        "responses": {
          "200": {
            "description": "The API process is running.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthLiveResponse"
                }
              }
            }
          },
          "500": {
            "description": "The API encountered an unexpected error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/session": {
      "get": {
        "operationId": "getAdminSession",
        "tags": [
          "Administration"
        ],
        "responses": {
          "200": {
            "description": "Current authenticated staff session.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdminSessionResponse"
                }
              }
            }
          },
          "401": {
            "description": "No authenticated staff session.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthenticatedResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}
