{
  "name": "@anshow/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "worker": "node dist/worker/index.js",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "auth:schema": "better-auth generate --config src/auth/schema-config.ts --output src/db/schema/auth.ts --yes",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js",
    "e2e:setup": "tsx scripts/prepare-e2e.ts",
    "admin:create": "tsx scripts/create-admin.ts",
    "admin:create:prod": "node dist/scripts/create-admin.js",
    "openapi:export": "tsx scripts/export-openapi.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@hono/zod-openapi": "^1.5.0",
    "@types/nodemailer": "^7.0.12",
    "argon2": "^0.44.0",
    "better-auth": "1.4.21",
    "better-sqlite3": "^12.11.1",
    "cos-nodejs-sdk-v5": "^3.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "nodemailer": "^7.0.13",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@eslint/js": "^9.39.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.43",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
